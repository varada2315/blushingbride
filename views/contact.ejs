<%- include('partials/header') %>

<!-- ==========================================================================
     HERO COVER (LIGHT THEME)
     ========================================================================== -->
<section class="section theme-white" style="padding-top: 150px; padding-bottom: 60px; text-align: center;">
    <div class="container">
        <h2 style="font-size: 4rem; color: var(--color-black); margin-bottom: 10px;">Contact Us</h2>
        <p style="font-family: var(--font-sans); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.25em; color: #8c7f75;">Let's tell your story together</p>
    </div>
</section>

<!-- ==========================================================================
     CONTACT CONTENT SECTION
     ========================================================================== -->
<section class="section theme-white fade-in-section" style="padding-top: 20px; padding-bottom: 120px;">
    <div class="container">
        <div class="contact-layout">
            
            <!-- Left: Sidebar Info -->
            <div class="contact-info-sidebar">
                <div class="contact-info-block">
                    <p style="font-family: var(--font-sans); font-size: 0.95rem; line-height: 1.8; opacity: 0.8; font-weight: 300;">
                        Please fill in the form and provide as much detail as possible. This helps us understand your vision, requirements, and events to draft a precise and bespoke quote.
                    </p>
                </div>
                
                <div class="contact-info-block">
                    <span class="contact-info-title">Email Us</span>
                    <a href="mailto:hello@houseontheclouds.com" class="contact-info-text" style="border-bottom: 1px solid rgba(0,0,0,0.15); padding-bottom: 5px; align-self: flex-start;">hello@houseontheclouds.com</a>
                </div>

                <div class="contact-info-block">
                    <span class="contact-info-title">Call Us</span>
                    <span class="contact-info-text">+91 99647 87383</span>
                </div>

                <div class="contact-info-block">
                    <span class="contact-info-title">Offices</span>
                    <span class="contact-info-text" style="font-weight: 400;">Mumbai & Bangalore</span>
                    <span style="font-family: var(--font-sans); font-size: 0.8rem; opacity: 0.5;">House On The Clouds Private Limited</span>
                </div>
            </div>

            <!-- Right: Interactive Form -->
            <div>
                <!-- Form Feedback Notification (Hidden by default, shown upon successful submission) -->
                <div class="form-feedback"></div>
                
                <form id="contactForm" class="contact-form" novalidate>
                    <div class="form-group-row">
                        <!-- First Name -->
                        <div class="form-group">
                            <input type="text" id="firstName" name="firstName" class="form-control" placeholder=" " required>
                            <label for="firstName" class="form-label">First Name *</label>
                        </div>
                        
                        <!-- Last Name -->
                        <div class="form-group">
                            <input type="text" id="lastName" name="lastName" class="form-control" placeholder=" " required>
                            <label for="lastName" class="form-label">Last Name *</label>
                        </div>
                    </div>

                    <div class="form-group-row">
                        <!-- Email -->
                        <div class="form-group">
                            <input type="email" id="email" name="email" class="form-control" placeholder=" " required>
                            <label for="email" class="form-label">Email Address *</label>
                        </div>

                        <!-- Phone -->
                        <div class="form-group">
                            <input type="tel" id="phone" name="phone" class="form-control" placeholder=" ">
                            <label for="phone" class="form-label">Phone Number</label>
                        </div>
                    </div>

                    <div class="form-group-row">
                        <!-- Event Dates -->
                        <div class="form-group">
                            <input type="text" id="eventDate" name="eventDate" class="form-control" placeholder=" ">
                            <label for="eventDate" class="form-label">Event Dates (e.g. Nov 12-14, 2026)</label>
                        </div>

                        <!-- Event Location -->
                        <div class="form-group">
                            <input type="text" id="eventLocation" name="eventLocation" class="form-control" placeholder=" ">
                            <label for="eventLocation" class="form-label">Event Location (City, Country)</label>
                        </div>
                    </div>

                    <!-- Services dropdown -->
                    <div class="form-group form-select-wrapper">
                        <select id="services" name="services" class="form-control form-select" placeholder=" " required>
                            <option value="" disabled selected hidden></option>
                            <option value="photography">Photography Only</option>
                            <option value="films">Films Only</option>
                            <option value="both">Both Photography & Films</option>
                            <option value="ibtida">Ibtida Fine-Art Package</option>
                        </select>
                        <label for="services" class="form-label">Services Required *</label>
                        <!-- Custom dropdown Arrow -->
                        <span class="form-select-icon">&#9662;</span>
                    </div>

                    <!-- Details message -->
                    <div class="form-group">
                        <textarea id="message" name="message" class="form-control" rows="4" placeholder=" " style="resize: none;"></textarea>
                        <label for="message" class="form-label">Tell us more about your wedding and story...</label>
                    </div>

                    <div>
                        <button type="submit" class="btn-primary dark-btn" style="border: none;">Send Inquiry</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</section>

<%- include('partials/footer') %>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="https://assets.squarespace.com/universal/default-favicon.ico">
    <!-- Google Fonts & Custom CSS -->
    <link rel="stylesheet" href="/css/index.css?v=<%= Date.now() %>">
</head>
<body class="<%= (activePage === 'our-story' || activePage === 'blogs' || activePage === 'contact') ? 'theme-white' : 'theme-black' %>">

    <!-- Header Navigation -->
    <header class="header-nav <%= (activePage === 'our-story' || activePage === 'blogs' || activePage === 'contact') ? 'nav-light-bg' : '' %>">
        <!-- Logo (Left) -->
        <a href="/" class="logo-container">
            <h1 class="logo-text">
                Blushing Bride
                <span>Photography & Films</span>
            </h1>
        </a>

        <!-- Center/Right Navigation Links -->
        <nav style="display: flex; align-items: center; gap: 30px;">
            <ul class="nav-menu">
                <li><a href="/" class="nav-link <%= activePage === 'home' ? 'active' : '' %>">Home</a></li>
                <li><a href="/portfolio" class="nav-link <%= activePage === 'portfolio' ? 'active' : '' %>">Portfolio</a></li>
                <li><a href="/our-story" class="nav-link <%= activePage === 'our-story' ? 'active' : '' %>">Our Story</a></li>
                <li><a href="/blogs" class="nav-link <%= activePage === 'blogs' ? 'active' : '' %>">Blogs</a></li>
                
                <!-- More Dropdown -->
                <li class="nav-dropdown-wrapper">
                    <a href="#" class="nav-link dropdown-trigger">More <span style="font-size: 0.6rem; vertical-align: middle;">&#9662;</span></a>
                    <ul class="nav-dropdown">
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Travel</a></li>
                        <li><a href="#">Backyard</a></li>
                    </ul>
                </li>
            </ul>

            <!-- Social Icons in Header -->
            <div class="nav-social-icons" style="display: flex; gap: 15px; align-items: center; margin-left: 20px;">
                <a href="https://instagram.com" target="_blank" aria-label="Instagram">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051C.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                    </svg>
                </a>
                <a href="https://facebook.com" target="_blank" aria-label="Facebook">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                    </svg>
                </a>
                <a href="https://twitter.com" target="_blank" aria-label="Twitter">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                </a>
            </div>

            <!-- Primary CTA Button, Gold Accent -->
            <a href="/contact" class="btn-nav-action" style="margin-left: 20px;">Get In Touch</a>
        </nav>

        <!-- Mobile Burger Menu Button -->
        <button class="burger-menu" aria-label="Toggle Navigation Menu">
            <div class="burger-line line-1"></div>
            <div class="burger-line line-2"></div>
            <div class="burger-line line-3"></div>
        </button>
    </header>

    <!-- Mobile Navigation Overlay Drawer -->
    <div class="mobile-nav-overlay">
        <ul class="mobile-nav-menu">
            <li>
                <a href="/" class="mobile-nav-link">
                    Home
                    <span>Start Here</span>
                </a>
            </li>
            <li>
                <a href="/portfolio" class="mobile-nav-link">
                    Portfolio
                    <span>Our Works</span>
                </a>
            </li>
            <li>
                <a href="/our-story" class="mobile-nav-link">
                    Our Story
                    <span>About Us</span>
                </a>
            </li>
            <li>
                <a href="/blogs" class="mobile-nav-link">
                    Blogs
                    <span>Latest Updates</span>
                </a>
            </li>
            <li>
                <a href="/contact" class="mobile-nav-link">
                    Contact Us
                    <span>Get In Touch</span>
                </a>
            </li>
        </ul>
    </div>
